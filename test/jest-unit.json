{
  "moduleFileExtensions": ["js", "json", "ts"],
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "rootDir": "..",
  "roots": ["<rootDir>/src", "<rootDir>/test/unit"],
  "testEnvironment": "node",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": ["src/**/*.(t|j)s", "!**/*.spec.ts", "!**/*.e2e-spec.ts"],
  "coverageDirectory": "../coverage"
}
